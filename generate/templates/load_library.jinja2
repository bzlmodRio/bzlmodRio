load("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

def load_{{repo.replace('-', "_")}}(version):
    if version == None:
        print("Not using {{repo}}")
        return

    if version == "local":
        print("Using local {{repo}}")
        native.local_repository(
            name = "{{repo}}",
            path = "../../{{repo.replace('bzlmodrio', 'bzlmodRio')}}",
        )
        return
{%- for version, version_info in repo_info.items() %}
    elif version == "{{version}}":
        sha = "{{version_info.sha}}"
        committish = "{{version_info.commitish}}"
{%- endfor %}
    else:
        fail("Unsupported version {}".format(version))

    http_archive(
        name = "{{repo}}",
        sha256 = sha,
        strip_prefix = "bzlmodRio-{{repo}}-{}".format(committish),
        url = "https://github.com/bzlmodRio/bzlmodRio-{{repo}}/archive/{}.tar.gz".format(committish),
    )